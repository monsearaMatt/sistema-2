generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["Compras", "Inventario", "Logistica", "Maestros", "RRHH", "SI1", "SIA", "Ventas"]
}

model direccion {
  id_direccion      Int                 @id @default(autoincrement())
  direccion         String?             @db.VarChar(255)
  id_cliente        Int?
  clientes          clientes?           @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, map: "FK_logistica_direccion_cliente")
  log_guia_despacho log_guia_despacho[]

  @@schema("Logistica")
}

model log_guia_despacho {
  id_guia           Int                @id @default(autoincrement())
  id_ot             Int?
  id_transportista  Int?
  id_direccion      Int?
  fecha_emision     DateTime?          @db.Timestamp(6)
  direccion         direccion?         @relation(fields: [id_direccion], references: [id_direccion], onDelete: NoAction, onUpdate: NoAction, map: "fk_guia_dir")
  log_picking       log_picking?       @relation(fields: [id_ot], references: [id_ot], onDelete: NoAction, onUpdate: NoAction, map: "fk_guia_ot")
  log_transportista log_transportista? @relation(fields: [id_transportista], references: [id_transportista], onDelete: NoAction, onUpdate: NoAction, map: "fk_guia_transp")

  @@schema("Logistica")
}

model log_picking {
  id_ot             Int                 @id @default(autoincrement())
  id_pedido_venta   Int?
  id_empleado       Int?
  fecha_creacion    DateTime?           @db.Timestamp(6)
  estado            String?             @db.VarChar(50)
  log_guia_despacho log_guia_despacho[]
  RRHH_empleado     RRHH_empleado?      @relation(fields: [id_empleado], references: [id_empleado], onDelete: NoAction, onUpdate: NoAction, map: "fk_picking_empleado")

  @@schema("Logistica")
}

model log_recepcion {
  id_recepcion    Int            @id @default(autoincrement())
  id_orden_compra String?        @db.Uuid
  id_empleado     Int?
  fecha_recepcion DateTime?      @db.Timestamp(6)
  RRHH_empleado   RRHH_empleado? @relation(fields: [id_empleado], references: [id_empleado], onDelete: NoAction, onUpdate: NoAction, map: "fk_recepcion_empleado")

  @@schema("Logistica")
}

model log_transportista {
  id_transportista  Int                 @id @default(autoincrement())
  nombre_transp     String?             @db.VarChar(100)
  patente_vehiculo  String?             @db.VarChar(10)
  id_empleado       Int?
  log_guia_despacho log_guia_despacho[]
  RRHH_empleado     RRHH_empleado?      @relation(fields: [id_empleado], references: [id_empleado], onDelete: NoAction, onUpdate: NoAction, map: "fk_transp_empleado")

  @@schema("Logistica")
}

model RRHH_empleado {
  id_empleado       Int                 @id @default(autoincrement())
  rut               String?             @db.VarChar(12)
  nombre            String?             @db.VarChar(100)
  id_rol            Int?
  correo            String?             @db.VarChar(100)
  telefono          String?             @db.VarChar(20)
  estado            String?             @db.VarChar(50)
  log_picking       log_picking[]
  log_recepcion     log_recepcion[]
  log_transportista log_transportista[]
  RRHH_rol          RRHH_rol?           @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction, map: "fk_empleado_rol")
  RRHH_solicitud    RRHH_solicitud[]
  RRHH_usuario      RRHH_usuario[]

  @@schema("RRHH")
}

model RRHH_rol {
  id_rol        Int             @id @default(autoincrement())
  name_rol      String?         @db.VarChar(100)
  RRHH_empleado RRHH_empleado[]

  @@schema("RRHH")
}

model RRHH_solicitud {
  id_solicitud   Int            @id @default(autoincrement())
  id_empleado    Int?
  tipo_solicitud String?        @db.VarChar(100)
  fecha_inicio   DateTime?      @db.Date
  fecha_fin      DateTime?      @db.Date
  estado         String?        @db.VarChar(50)
  RRHH_empleado  RRHH_empleado? @relation(fields: [id_empleado], references: [id_empleado], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitud_empleado")

  @@schema("RRHH")
}

model RRHH_usuario {
  id_usuario    Int            @id @default(autoincrement())
  username      String?        @db.VarChar(50)
  password      String?        @db.VarChar(255)
  id_empleado   Int?
  RRHH_empleado RRHH_empleado? @relation(fields: [id_empleado], references: [id_empleado], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_empleado")

  @@schema("RRHH")
}

model Detalle_OC {
  id_detalle        String      @id(map: "PK_f6ff6869fdf5754c19d26fbad42") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  id_oc             String      @db.Uuid
  cantidad          Int
  precio_unitario   Int
  cantidad_recibida Int?
  id_producto       String      @db.VarChar
  nombre_producto   String      @db.VarChar
  OrdenCompra       OrdenCompra @relation(fields: [id_oc], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_e223fb248c2f286d1161a65921a")

  @@schema("Compras")
}

model OrdenCompra {
  id             String       @id(map: "PK_908a824cc7526bdada14df09062") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  id_proveedor   String       @db.Uuid
  fecha_creacion DateTime     @default(now()) @db.Timestamp(6)
  estado         String       @default("PENDIENTE") @db.VarChar(20)
  total          Int
  id_usuario     String       @db.Uuid
  ingresada      Boolean      @default(false)
  Detalle_OC     Detalle_OC[]
  Proveedor      Proveedor    @relation(fields: [id_proveedor], references: [id], onUpdate: NoAction, map: "FK_44b189627e1858a5b891508bf6a")

  @@schema("Compras")
}

model ProductoProveedor {
  id           String    @id(map: "PK_a42c32875893264528ea84d1ffa") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre       String    @db.VarChar(255)
  precio       Int
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  updated_at   DateTime  @default(now()) @db.Timestamp(6)
  id_proveedor String    @db.Uuid
  Proveedor    Proveedor @relation(fields: [id_proveedor], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_3b66a740de7ec2fbedd0073ca2a")

  @@schema("Compras")
}

model Proveedor {
  id                String              @id(map: "PK_4d36ff46524e905a788b2114a0d") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rutEmpresa        String              @unique(map: "UQ_62199b319b7fac70d2e6690b5bd") @db.VarChar(12)
  email             String              @unique(map: "UQ_e79f047ec1f4c04ce90b32764f4") @db.VarChar(255)
  nombre            String              @db.VarChar(255)
  createdAt         DateTime            @default(now()) @db.Timestamp(6)
  updatedAt         DateTime            @default(now()) @db.Timestamp(6)
  telefono          String?             @db.VarChar(50)
  OrdenCompra       OrdenCompra[]
  ProductoProveedor ProductoProveedor[]

  @@schema("Compras")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model prueba {
  columa_prueba String? @db.VarChar

  @@ignore
  @@schema("Compras")
}

model Producto {
  id_producto    String           @id(map: "PK_ebdd9c48db83f711960a224dc46") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  codigo         String           @unique(map: "UQ_8aaae30e2e9c5d7fac2e891932d") @db.VarChar(12)
  nombre         String           @db.VarChar(255)
  precio         Decimal          @db.Decimal(10, 2)
  stock_actual   Int              @default(0)
  stock_minimo   Int              @default(0)
  createdAt      DateTime         @default(now()) @db.Timestamp(6)
  updatedAt      DateTime         @default(now()) @db.Timestamp(6)
  inv_movimiento inv_movimiento[]

  @@schema("Inventario")
}

model inv_movimiento {
  id_movimiento String                   @id(map: "PK_78215d6a86a5447f52a8f4c5364") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  imagen        String?                  @db.VarChar(255)
  tipo          inv_movimiento_tipo_enum
  cantidad      Int
  referencia    String?                  @db.VarChar(255)
  empleado_id   String?                  @db.VarChar
  fecha         DateTime                 @default(now()) @db.Timestamp(6)
  producto_id   String?                  @db.Uuid
  inv_producto  Producto?                @relation(fields: [producto_id], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "FK_e9724004d47f45fd45feeb327f8")

  @@schema("Inventario")
}

model SI1_alumno {
  rut             String    @id @db.VarChar(12)
  edad            Int?
  id_curso_alumno String    @db.VarChar(5)
  curso           SI1_curso @relation(fields: [id_curso_alumno], references: [id_curso_origen], onDelete: NoAction, onUpdate: NoAction, map: "fk_curso")

  @@map("alumno")
  @@schema("SI1")
}

model SI1_curso {
  id_curso_origen String       @id @db.VarChar(5)
  periodo         Int
  alumno          SI1_alumno[]

  @@map("curso")
  @@schema("SI1")
}

model SIA_alumno {
  rut                 String    @id @db.VarChar(12)
  edad                Int?
  id_curso_referencia String    @db.VarChar(5)
  curso               SIA_curso @relation(fields: [id_curso_referencia], references: [id_curso], onDelete: NoAction, onUpdate: NoAction, map: "fk_curso")

  @@map("alumno")
  @@schema("SIA")
}

model SIA_curso {
  id_curso String       @id @db.VarChar(5)
  year     Int
  alumno   SIA_alumno[]

  @@map("curso")
  @@schema("SIA")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model ProductoImagen {
  id           Int      @id(map: "pk_producto_imagen") @default(autoincrement())
  producto_id  Int
  imagen_url   String   @db.VarChar(1000)
  public_id    String?  @db.VarChar(500)
  es_principal Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([producto_id], map: "idx_producto_imagen_producto_id")
  @@schema("Ventas")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model carrito {
  id_carrito     Int       @id @default(autoincrement())
  id_sesion      String    @db.VarChar(50)
  id_cliente     Int?
  id_producto    Int
  cantidad       Int
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  clientes       clientes? @relation(fields: [id_cliente], references: [id_cliente], onUpdate: NoAction)

  @@index([id_cliente], map: "idx_carrito_cliente")
  @@index([id_sesion], map: "idx_carrito_sesion")
  @@schema("Ventas")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model clientes {
  id_cliente    Int             @id @default(autoincrement())
  rut           String?         @unique @db.VarChar(12)
  nombre        String          @db.VarChar(100)
  email         String          @db.VarChar(100)
  telefono      String?         @db.VarChar(15)
  tipo          String?         @db.VarChar(10)
  userId        String?         @unique @db.VarChar(255)
  password      String?         @db.VarChar(255)
  isRegistered  Boolean         @default(false)
  isActive      Boolean         @default(true)
  balance       Decimal         @default(0) @db.Decimal(10, 2)
  direccion     direccion[]
  carrito       carrito[]
  ventas_pedido ventas_pedido[]

  @@schema("Ventas")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ventas_detalle {
  id_detalle    Int           @id @default(autoincrement())
  id_pedido     Int
  id_producto   Int
  cantidad      Int
  precio_unit   Decimal       @db.Decimal(10, 2)
  subtotal      Decimal       @db.Decimal(10, 2)
  ventas_pedido ventas_pedido @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_detalle_pedido")
  @@schema("Ventas")
}

model ventas_factura {
  id_factura    Int           @id @default(autoincrement())
  id_pedido     Int           @unique
  fecha_emision DateTime?     @default(now()) @db.Timestamp(6)
  monto_neto    Decimal       @db.Decimal(10, 2)
  iva           Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  ventas_pedido ventas_pedido @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)

  @@schema("Ventas")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ventas_pedido {
  id_pedido      Int              @id @default(autoincrement())
  id_cliente     Int
  id_empleado    Int?
  fecha          DateTime?        @default(now()) @db.Timestamp(6)
  estado         String?          @default("pendiente") @db.VarChar(20)
  total          Decimal?         @db.Decimal(10, 2)
  canal          String?          @db.VarChar(20)
  subtotal       Decimal          @default(0) @db.Decimal(10, 2)
  costo_envio    Decimal          @default(0) @db.Decimal(10, 2)
  isPaid         Boolean          @default(false)
  paidAt         DateTime?        @db.Timestamptz(6)
  paymentMethod  String           @default("pendiente") @db.VarChar(50)
  notes          String?
  shippingInfo   Json?
  userId         String?          @db.VarChar(255)
  updatedAt      DateTime?        @default(now()) @db.Timestamp(6)
  ventas_detalle ventas_detalle[]
  ventas_factura ventas_factura?
  clientes       clientes         @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_cliente], map: "idx_pedido_cliente")
  @@schema("Ventas")
}

model maestro_cliente {
  id_cliente Int     @id @default(autoincrement())
  rut        String? @db.VarChar(20)
  nombre     String  @db.VarChar(200)
  correo     String? @db.VarChar(150)
  telefono   String? @db.VarChar(50)
  direccion  String? @db.VarChar(255)

  @@map("cliente")
  @@schema("Maestros")
}

model maestro_producto {
  id_producto     String   @id @db.Uuid
  sku             String?  @db.VarChar(100)
  nombre          String   @db.VarChar(200)
  descripcion     String?
  precio_unitario Decimal? @db.Decimal(12, 2)

  @@map("producto")
  @@schema("Maestros")
}

model maestro_proveedor {
  id_proveedor String  @id @db.Uuid
  nombre       String  @db.VarChar(200)
  contacto     String? @db.VarChar(150)
  correo       String? @db.VarChar(150)

  @@map("proveedor")
  @@schema("Maestros")
}

enum inv_movimiento_tipo_enum {
  ENTRADA
  SALIDA
  RESERVA

  @@schema("Inventario")
}
