# Copy this file to .env and edit values as needed.
# Default (used by docker-compose example):
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
PORT=3000

# --- External database usage ---
# If you're using an external PostgreSQL database, replace DATABASE_URL with
# your provider's connection string. Examples:
# Local Postgres: postgresql://user:password@localhost:5432/mydb
# Remote / managed (with SSL): postgresql://user:password@host:5432/mydb?sslmode=require
# PostgreSQL on cloud (Heroku/Azure/RDS) often provides a full URL; paste it here.

# Example for a managed DB (replace placeholders):
# DATABASE_URL=postgresql://DB_USER:DB_PASS@db.example.com:5432/DB_NAME?sslmode=require

# --- Prisma / migration commands ---
# After setting DATABASE_URL, run these commands from the backend folder:
# Install deps (if not already):
#   npm install
# Generate Prisma client:
#   npx prisma generate
# Apply migrations (production):
#   npx prisma migrate deploy
# For development (creates a migration and applies it):
#   npx prisma migrate dev --name init

# --- Run the backend ---
# Development mode:
#   npm run start:dev
# Build and run (production):
#   npm run build
#   npm run start:prod

# --- Notes for running with Docker Compose and an external DB ---
# If you prefer Docker but want to use your external DB, set DATABASE_URL in
# this .env file to point to the external host and ensure the container can
# reach it (network, firewall, allowed IPs). You can then run:
#   docker-compose up --build backend
# or disable/remove the `db` service in docker-compose.yml so it doesn't start
# a local Postgres instance.

# Keep other runtime environment variables here as needed.
